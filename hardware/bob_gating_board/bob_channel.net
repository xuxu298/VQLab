(export (version "E")
  (design
    (source "Bob detector — self-differencing gated InGaAs/InP SPAD front-end (H1)")
    (date "2026-05-26")
    (tool "QResearch hardware/bob_gating_board — hand-authored, KiCad-importable")
    (sheet (number "1") (name "/") (comment "one of 2 identical detector channels")))

  (components
    (comp (ref "J1")  (value "SMA gate in 1.25GHz")   (footprint "Connector_Coaxial:SMA_Amphenol_901-144"))
    (comp (ref "J2")  (value "-V_DC bias in")          (footprint "Connector_PinHeader_2.54mm:PinHeader_1x02"))
    (comp (ref "J3")  (value "V_th DAC in")            (footprint "Connector_PinHeader_2.54mm:PinHeader_1x02"))
    (comp (ref "J4")  (value "LVDS event out")         (footprint "Connector_PinHeader_2.54mm:PinHeader_1x02"))
    (comp (ref "C1")  (value "100pF NP0")              (footprint "Capacitor_SMD:C_0402_1005Metric") (datasheet "DC block, gate arm of bias-tee"))
    (comp (ref "C2")  (value "100pF NP0")              (footprint "Capacitor_SMD:C_0402_1005Metric") (datasheet "DC block, readout"))
    (comp (ref "L1")  (value "470nH RF choke")         (footprint "Inductor_SMD:L_0603_1608Metric")   (datasheet "bias-tee DC arm, SRF > 2 GHz"))
    (comp (ref "R1")  (value "50R")                    (footprint "Resistor_SMD:R_0402_1005Metric")   (datasheet "readout termination"))
    (comp (ref "D1")  (value "InGaAs/InP SPAD")        (footprint "QResearch:SPAD_TO46_TEC")           (datasheet "Laser Components IAG-series / Wooriro"))
    (comp (ref "U1")  (value "Wilkinson splitter")     (footprint "QResearch:RF_Wilkinson_DC-3GHz")    (datasheet "or microstrip structure in layout"))
    (comp (ref "DL1") (value "coax delay 0.80ns")      (footprint "QResearch:CoaxDelay_1period")       (datasheet "length-tuned semi-rigid; = 1 gate period"))
    (comp (ref "U2")  (value "180deg hybrid")          (footprint "QResearch:RF_Hybrid180_DC-3GHz")    (datasheet "analog subtraction A-B"))
    (comp (ref "U3")  (value "PGA-103+")               (footprint "Package_TO_SOT_SMD:Minicircuits_MCL_PGA-103") (datasheet "LNA, NF<1dB"))
    (comp (ref "U4")  (value "ADCMP572")               (footprint "Package_BGA:Analog_ADCMP572_BGA")   (datasheet "fast comparator, LVPECL/LVDS"))
    (comp (ref "U6")  (value "AD5535B")                (footprint "Package_BGA:Analog_AD5535_BGA")     (datasheet "32-ch 200V HV DAC -> -V_DC bias")))

  (nets
    (net (code "1") (name "GATE_IN")
      (node (ref "J1") (pin "1")) (node (ref "C1") (pin "1")))
    (net (code "2") (name "N_CATHODE")
      (node (ref "C1") (pin "2")) (node (ref "L1") (pin "2")) (node (ref "D1") (pin "K")))
    (net (code "3") (name "BIAS_HV")
      (node (ref "L1") (pin "1")) (node (ref "J2") (pin "1")) (node (ref "U6") (pin "VOUT")))
    (net (code "4") (name "N_READOUT")
      (node (ref "D1") (pin "A")) (node (ref "R1") (pin "1")) (node (ref "C2") (pin "1")))
    (net (code "5") (name "N_RF")
      (node (ref "C2") (pin "2")) (node (ref "U1") (pin "IN")))
    (net (code "6") (name "ARM_A_DIRECT")
      (node (ref "U1") (pin "OUT1")) (node (ref "U2") (pin "A")))
    (net (code "7") (name "ARM_B_PRE")
      (node (ref "U1") (pin "OUT2")) (node (ref "DL1") (pin "1")))
    (net (code "8") (name "ARM_B_DELAYED")
      (node (ref "DL1") (pin "2")) (node (ref "U2") (pin "B")))
    (net (code "9") (name "SD_OUT")
      (node (ref "U2") (pin "DELTA")) (node (ref "U3") (pin "IN")))
    (net (code "10") (name "LNA_OUT")
      (node (ref "U3") (pin "OUT")) (node (ref "U4") (pin "INP")))
    (net (code "11") (name "VTH")
      (node (ref "J3") (pin "1")) (node (ref "U4") (pin "INN")))
    (net (code "12") (name "LVDS_OUT")
      (node (ref "U4") (pin "OUT")) (node (ref "J4") (pin "1")))
    (net (code "13") (name "GND")
      (node (ref "J1") (pin "2")) (node (ref "J2") (pin "2")) (node (ref "J3") (pin "2"))
      (node (ref "J4") (pin "2")) (node (ref "R1") (pin "2"))
      (node (ref "U3") (pin "GND")) (node (ref "U4") (pin "GND")))))
